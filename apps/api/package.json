{
	"name": "api",
	"version": "1.0.0",
	"type": "module",
	"private": true,
	"scripts": {
		"dev": "bun run --watch src/index.ts",
		"build": "bun build src/index.ts --outdir=dist --target=bun --external sharp",
		"start": "bun run dist/index.js",
		"check-types": "tsc --noEmit",
		"clean": "rm -rf dist .turbo"
	},
	"dependencies": {
		"@elysiajs/cors": "^1.3.5",
		"@elysiajs/openapi": "^1.4.13",
		"@openrouter/sdk": "^0.3.15",
		"@repo/database": "*",
		"@repo/types": "*",
		"@repo/validations": "*",
		"better-auth": "^1.4.15",
		"dotenv": "^16.5.0",
		"effect": "^3.19.14",
		"elysia": "^1.4.21",
		"pino": "^10.3.0",
		"pino-pretty": "^13.1.3",
		"resend": "^6.7.0",
		"sharp": "^0.34.5",
		"uploadthing": "^7.7.4",
		"zod": "^3.25.0"
	},
	"devDependencies": {
		"@repo/typescript-config": "*",
		"@types/bun": "latest",
		"typescript": "5.9.2"
	}
}