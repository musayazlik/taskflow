{
	"name": "api",
	"version": "1.0.0",
	"type": "module",
	"private": true,
	"scripts": {
		"dev": "bun run --watch src/nest/main.ts",
		"build": "bun build src/nest/main.ts --outdir=dist --target=bun --external sharp --external mqtt --external nats --external kafkajs --external amqplib --external amqp-connection-manager --external ioredis --external @grpc/grpc-js --external @grpc/proto-loader --external class-transformer/storage",
		"start": "bun run dist/main.js",
		"check-types": "tsc --noEmit",
		"clean": "rm -rf dist .turbo"
	},
	"dependencies": {
		"@nestjs/common": "^10.4.5",
		"@nestjs/core": "^10.4.5",
		"@nestjs/microservices": "^10.4.5",
		"@nestjs/platform-express": "^10.4.5",
		"@nestjs/platform-socket.io": "10.4.5",
		"@nestjs/swagger": "^8.0.0",
		"@nestjs/websockets": "^10.4.5",
		"@repo/database": "*",
		"@repo/types": "*",
		"@repo/validations": "*",
		"@sinclair/typebox": "^0.34.0",
		"better-auth": "^1.4.15",
		"class-transformer": "^0.5.1",
		"class-validator": "^0.14.1",
		"dotenv": "^16.5.0",
		"effect": "^3.19.14",
		"multer": "^1.4.5-lts.1",
		"pino": "^10.3.0",
		"pino-pretty": "^13.1.3",
		"reflect-metadata": "^0.2.2",
		"resend": "^6.7.0",
		"rxjs": "^7.8.1",
		"sharp": "^0.34.5",
		"socket.io": "^4.8.3",
		"swagger-ui-express": "^5.0.1",
		"uploadthing": "^7.7.4",
		"zod": "^3.25.0"
	},
	"devDependencies": {
		"@repo/typescript-config": "*",
		"@types/express": "^4.17.21",
		"@types/multer": "^1.4.12",
		"@types/bun": "latest",
		"typescript": "5.9.2"
	}
}