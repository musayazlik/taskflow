# ============================================
# API ENVIRONMENT VARIABLES - DEVELOPMENT BRANCH
# ============================================

# Database URL
DATABASE_URL=""

# API Server
PORT=4101
FRONTEND_URL="http://localhost:4100"

# Optional: comma-separated extra origins for Socket.IO CORS (www vs apex, previews)
# SOCKET_CORS_ORIGINS="https://www.example.com"

# Auth (JWT)
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# Session (Next.js Server-side)
SESSION_SECRET="your-session-secret-key-change-in-production"

# Better Auth
BETTER_AUTH_URL="http://localhost:4101"
BETTER_AUTH_SECRET="your-better-auth-secret-key-change-in-production"
# Optional: extra trusted origins (comma-separated) for auth callbacks/cookies
# AUTH_TRUSTED_ORIGINS="https://taskflow.musayazlik.com,https://taskflow-api.musayazlik.com"

# Email (Resend)
RESEND_API_KEY=""
FROM_EMAIL=""
APP_NAME=""

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Docs Auth
DOCS_USERNAME=""
DOCS_PASSWORD=""

# AI (OpenRouter)
OPENROUTER_API_KEY=""

# UploadThing
UPLOADTHING_TOKEN=""

# Polar.sh Payment Integration
POLAR_ACCESS_TOKEN=""
POLAR_WEBHOOK_SECRET=""


# Google Diagnostics & Verification
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=""
GOOGLE_VERIFICATION_TOKEN=""