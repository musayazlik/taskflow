// ============================================
// AI Models
// ============================================

model AiModel {
  id          String   @id @default(cuid())
  name        String   // Display name: "GPT-4o", "Claude 3.5 Sonnet"
  provider    String   // "openrouter", "openai", "anthropic", "google"
  modelId     String   @unique // API model ID: "openai/gpt-4o", "anthropic/claude-3.5-sonnet"
  description String?
  contextSize Int?     // Context window size in tokens
  pricing     Json?    // { inputPerMillion: 2.50, outputPerMillion: 10.00 }

  /// High-level capabilities for feature gating
  /// e.g. ["chat", "vision", "function_calling", "json_mode"]
  capabilities String[]

  /// Modalities this model can accept as input, mapped from OpenRouter
  /// e.g. ["text", "image", "audio", "video", "file"]
  inputModalities  String[] @default([])

  /// Modalities this model can produce as output, mapped from OpenRouter
  /// e.g. ["text", "image", "audio"]
  outputModalities String[] @default([])

  /// Convenience flag so we can quickly query "image-capable" models
  /// Derived from outputModalities containing "image"
  supportsImageOutput Boolean @default(false)

  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("ai_model")
}

// ============================================
// Chat History
// ============================================

model ChatSession {
  id        String   @id @default(cuid())
  userId    String   // User who owns this session
  title     String   // Chat title (first message preview or custom)
  modelId   String   // AI model used for this session
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  messages ChatSessionMessage[]
  user     User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isActive])
  @@index([createdAt])
  @@map("chat_session")
}

model ChatSessionMessage {
  id         String   @id @default(cuid())
  sessionId  String
  role       String   // "user", "assistant", "system"
  content    String   // Message content
  tokensUsed Int?     // Token count for this message
  createdAt  DateTime @default(now())

  // Relations
  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([sessionId, createdAt])
  @@map("chat_session_message")
}
