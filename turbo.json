{
	"$schema": "https://turborepo.com/schema.json",
	"ui": "tui",
	"tasks": {
		"build": {
			"dependsOn": [
				"^build"
			],
			"inputs": [
				"$TURBO_DEFAULT$",
				".env*"
			],
			"outputs": [
				".next/**",
				"!.next/cache/**",
				"dist/**"
			]
		},
		"web#build": {
			"dependsOn": [
				"^build"
			],
			"env": [
				"NEXT_PRIVATE_SKIP_PATCHING"
			],
			"inputs": [
				"$TURBO_DEFAULT$",
				".env*"
			],
			"outputs": [
				".next/**",
				"!.next/cache/**"
			]
		},
		"lint": {
			"dependsOn": [
				"^lint"
			],
			"inputs": [
				"$TURBO_DEFAULT$"
			],
			"outputs": []
		},
		"check-types": {
			"dependsOn": [
				"^check-types"
			],
			"inputs": [
				"$TURBO_DEFAULT$"
			],
			"outputs": []
		},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"db:generate": {
			"cache": false
		},
		"db:push": {
			"cache": false
		},
		"db:migrate": {
			"cache": false
		},
		"db:studio": {
			"cache": false,
			"persistent": true
		},
		"db:reset": {
			"cache": false
		},
		"db:seed": {
			"cache": false
		},
		"clean": {
			"cache": false
		}
	}
}